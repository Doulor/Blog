---
import * as bcryptjs from "bcryptjs";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

export interface Props {
	encryptedPayload: string;
	password: string;
}

const { encryptedPayload, password } = Astro.props;
const passwordHash = bcryptjs.hashSync(password, 10);
---

<div id="diary-password-protection" class="diary-password-protection">
	<div class="diary-password-container">
		<div class="diary-lock-mark">私密日记</div>
		<h2>{i18n(I18nKey.passwordProtectedTitle)}</h2>
		<p>这篇日记已被完整隐藏，请输入密码查看正文和媒体内容。</p>
		<div class="diary-password-input-group">
			<input
				type="password"
				id="diary-password-input"
				placeholder={i18n(I18nKey.passwordPlaceholder)}
				class="diary-password-input"
			/>
			<button id="diary-unlock-btn" class="diary-unlock-button" type="button">{i18n(I18nKey.passwordUnlock)}</button>
		</div>
		<div id="diary-password-error" class="diary-password-error" hidden>{i18n(I18nKey.passwordIncorrect)}</div>
	</div>
</div>

<div id="diary-unlocked-status" class="diary-unlocked-status" hidden>加密日记，已解锁🔓</div>
<div id="diary-decrypted-content" class="diary-decrypted-content" hidden></div>

<style is:global>
	.diary-password-protection {
		display: flex;
		justify-content: center;
		align-items: center;
		min-height: 48vh;
		padding: 2rem 1rem;
	}

	.diary-password-container {
		width: min(100%, 28rem);
		padding: 2rem;
		border-radius: 1rem;
		background: var(--card-bg);
		border: 1px solid var(--line-divider);
		box-shadow: 0 1rem 2.5rem rgb(0 0 0 / 0.12);
		text-align: center;
	}

	.diary-lock-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 0.85rem;
		padding: 0.38rem 0.85rem;
		border-radius: 999px;
		background: color-mix(in oklch, var(--primary) 14%, transparent);
		color: var(--primary);
		font-weight: 800;
		font-size: 0.92rem;
	}

	.diary-password-container h2 {
		margin: 0 0 0.55rem;
		font-size: 1.4rem;
		font-weight: 800;
		color: rgba(0, 0, 0, 0.86);
	}

	:global(.dark) .diary-password-container h2 {
		color: rgba(255, 255, 255, 0.88);
	}

	.diary-password-container p {
		margin: 0 0 1.35rem;
		color: rgba(0, 0, 0, 0.68);
		line-height: 1.65;
	}

	:global(.dark) .diary-password-container p {
		color: rgba(255, 255, 255, 0.72);
	}

	.diary-password-input-group {
		display: flex;
		gap: 0.5rem;
	}

	.diary-password-input {
		min-width: 0;
		flex: 1;
		padding: 0.75rem 0.9rem;
		border-radius: 0.65rem;
		border: 1px solid var(--line-divider);
		background: var(--card-bg);
		color: rgba(0, 0, 0, 0.85);
		font-size: 1rem;
	}

	:global(.dark) .diary-password-input {
		color: rgba(255, 255, 255, 0.86);
	}

	.diary-password-input:focus {
		outline: none;
		border-color: var(--primary);
		box-shadow: 0 0 0 3px color-mix(in oklch, var(--primary) 18%, transparent);
	}

	.diary-unlock-button {
		padding: 0.75rem 1.15rem;
		border: 0;
		border-radius: 0.65rem;
		background: var(--primary);
		color: white;
		font-weight: 700;
		cursor: pointer;
	}

	.diary-unlock-button:disabled {
		opacity: 0.62;
		cursor: not-allowed;
	}

	.diary-password-error {
		margin-top: 0.8rem;
		color: #ef4444;
		font-size: 0.88rem;
	}

	.diary-decrypted-content {
		animation: diaryFadeIn 0.25s ease-out;
	}

	.diary-decrypted-content .markdown-content p {
		white-space: pre-wrap;
	}

	.diary-unlocked-status {
		margin-bottom: 1rem;
		padding: 0.75rem 1rem;
		border-radius: 0.75rem;
		border: 1px solid color-mix(in oklch, var(--primary) 42%, transparent);
		background: color-mix(in oklch, var(--primary) 10%, transparent);
		color: var(--primary);
		font-weight: 800;
		text-align: center;
	}

	.diary-decrypted-section {
		margin-top: 1.5rem;
	}

	.diary-decrypted-section-title {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		margin-bottom: 0.75rem;
		color: var(--text-75, currentColor);
		font-size: 0.9rem;
		font-weight: 700;
	}

	.diary-decrypted-grid {
		display: grid;
		grid-template-columns: repeat(1, minmax(0, 1fr));
		gap: 0.75rem;
	}

	@media (min-width: 640px) {
		.diary-decrypted-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 768px) {
		.diary-decrypted-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.diary-decrypted-media {
		position: relative;
		display: block;
		aspect-ratio: 1 / 1;
		border-radius: 0.75rem;
		overflow: hidden;
		border: 1px solid var(--line-divider);
		background: var(--card-bg);
		cursor: pointer;
	}

	.diary-decrypted-media img,
	.diary-decrypted-media video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.diary-decrypted-video-fallback {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgb(0 0 0 / 0.42);
		color: white;
		font-size: 0.9rem;
	}

	.diary-decrypted-video-play {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}

	.diary-decrypted-video-play span {
		width: 3rem;
		height: 3rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: rgb(0 0 0 / 0.55);
		color: white;
		font-size: 1.25rem;
	}

	@keyframes diaryFadeIn {
		from {
			opacity: 0;
			transform: translateY(0.5rem);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 520px) {
		.diary-password-container {
			padding: 1.5rem;
		}

		.diary-password-input-group {
			flex-direction: column;
		}
	}
</style>

<script is:inline define:vars={{
	encryptedPayload,
	passwordHash,
	i18nUnlocking: i18n(I18nKey.passwordUnlocking),
	i18nIncorrect: i18n(I18nKey.passwordIncorrect),
	i18nDecryptError: i18n(I18nKey.passwordDecryptError),
	i18nUnlock: i18n(I18nKey.passwordUnlock)
}}>
	(function () {
		async function loadCryptoLibraries() {
			if (typeof CryptoJS === 'undefined') {
				await new Promise((resolve, reject) => {
					const script = document.createElement('script');
					script.src = '/assets/js/crypto-js.min.js';
					script.onload = resolve;
					script.onerror = reject;
					document.head.appendChild(script);
				});
			}

			if (typeof bcrypt === 'undefined') {
				await new Promise((resolve, reject) => {
					const script = document.createElement('script');
					script.src = '/assets/js/bcrypt.min.js';
					script.onload = resolve;
					script.onerror = reject;
					document.head.appendChild(script);
				});
			}
		}

		async function loadMarkdownRenderer() {
			if (typeof marked === 'undefined') {
				await new Promise((resolve, reject) => {
					const script = document.createElement('script');
					script.src = '/assets/js/marked.min.js';
					script.onload = resolve;
					script.onerror = reject;
					document.head.appendChild(script);
				});
			}
			marked.setOptions({ breaks: true, gfm: true });
		}

		function normalizeMediaValue(value) {
			const raw = String(value || '').trim();
			const markdownMatch = raw.match(/\((https?:[^)]+)\)/i);
			return markdownMatch ? markdownMatch[1].trim() : raw;
		}

		function resolveMediaSrc(value, basePath) {
			const normalized = normalizeMediaValue(value);
			if (/^(https?:|data:|blob:|\/)/i.test(normalized)) return normalized;
			return `${String(basePath || '').replace(/\\/g, '/').replace(/\/+$/, '')}/${normalized.replace(/^\/+/, '')}`;
		}

		function isImageUrl(value) {
			return /\.(png|jpe?g|gif|webp|avif|svg|bmp)(\?|#|$)/i.test(normalizeMediaValue(value));
		}

		function isDirectVideoUrl(value) {
			return /\.(mp4|webm|ogg|mov|m4v|m3u8|mpd)(\?|#|$)/i.test(String(value || ''));
		}

		function getVideoMimeType(value) {
			const src = String(value || '').split('?')[0].split('#')[0].toLowerCase();
			if (src.endsWith('.mp4') || src.endsWith('.m4v')) return 'video/mp4';
			if (src.endsWith('.webm')) return 'video/webm';
			if (src.endsWith('.ogg')) return 'video/ogg';
			if (src.endsWith('.mov')) return 'video/quicktime';
			if (src.endsWith('.m3u8')) return 'application/x-mpegURL';
			if (src.endsWith('.mpd')) return 'application/dash+xml';
			return '';
		}

		function addHeadingAnchors(container) {
			const headings = container.querySelectorAll('h1, h2, h3, h4, h5, h6');
			const usedIds = new Set();
			headings.forEach((heading) => {
				let slug = String(heading.textContent || '')
					.toLowerCase()
					.trim()
					.replace(/[^\w\s-]/g, '')
					.replace(/[\s_-]+/g, '-')
					.replace(/^-+|-+$/g, '');
				if (!slug) slug = 'heading';
				let uniqueSlug = slug;
				let counter = 1;
				while (usedIds.has(uniqueSlug)) {
					uniqueSlug = `${slug}-${counter}`;
					counter += 1;
				}
				usedIds.add(uniqueSlug);
				heading.id = uniqueSlug;
				const anchor = document.createElement('a');
				anchor.className = 'anchor';
				anchor.href = `#${uniqueSlug}`;
				const icon = document.createElement('span');
				icon.className = 'anchor-icon';
				icon.setAttribute('data-pagefind-ignore', 'true');
				icon.textContent = '#';
				anchor.append(icon);
				heading.append(anchor);
			});
		}

		function preserveDiaryTextNewlines(markdownText) {
			const lines = String(markdownText || '').replace(/\r\n/g, '\n').split('\n');
			let inFence = false;
			return lines.map((line) => {
				if (/^\s*(```|~~~)/.test(line)) {
					inFence = !inFence;
					return line;
				}
				if (inFence || !line.trim()) return line;
				if (/^\s{0,3}(#{1,6}\s|[-*+]\s|\d+\.\s|>\s|[-*_]{3,}\s*$|!\[|\[.*\]:)/.test(line)) return line;
				return `${line}  `;
			}).join('\n');
		}

		function renderMarkdown(markdownText, container) {
			const wrapper = document.createElement('div');
			wrapper.className = 'prose dark:prose-invert prose-base !max-w-none custom-md mb-8 markdown-content onload-animation';
			wrapper.setAttribute('data-pagefind-body', '');
			wrapper.innerHTML = marked.parse(preserveDiaryTextNewlines(markdownText));
			wrapper.querySelectorAll('p, li, blockquote').forEach((element) => {
				element.style.whiteSpace = 'pre-wrap';
			});
			wrapper.querySelectorAll('p').forEach((element) => {
				element.style.textIndent = '2em';
			});
			wrapper.querySelectorAll('li p, blockquote p').forEach((element) => {
				element.style.textIndent = '0';
			});
			addHeadingAnchors(wrapper);
			container.append(wrapper);
		}

		function renderImages(images, payload, container) {
			const imageItems = (images || []).filter(isImageUrl);
			if (!imageItems.length) return;

			const section = document.createElement('section');
			section.className = 'diary-decrypted-section space-y-3';
			section.innerHTML = `<div class="diary-decrypted-section-title"><span>📷</span><span>图片</span><span>(${imageItems.length})</span></div>`;
			const grid = document.createElement('div');
			grid.className = 'diary-decrypted-grid';
			imageItems.forEach((item, index) => {
				const src = resolveMediaSrc(item, payload.basePath);
				const link = document.createElement('a');
				link.className = 'diary-decrypted-media';
				link.href = src;
				link.setAttribute('data-lightbox-src', src);
				link.setAttribute('aria-label', `${payload.title || 'Diary'} - ${index + 1}`);
				const img = document.createElement('img');
				img.src = src;
				img.alt = `${payload.title || 'Diary'} - ${index + 1}`;
				img.loading = 'lazy';
				img.decoding = 'async';
				link.append(img);
				grid.append(link);
			});
			section.append(grid);
			container.append(section);
		}

		function renderVideos(images, videos, payload, container) {
			const videoItems = [...(videos || []), ...(images || []).filter((item) => !isImageUrl(item))];
			if (!videoItems.length) return;

			const section = document.createElement('section');
			section.className = 'diary-decrypted-section space-y-3';
			section.innerHTML = `<div class="diary-decrypted-section-title"><span>🎬</span><span>视频</span><span>(${videoItems.length})</span></div>`;
			const grid = document.createElement('div');
			grid.className = 'diary-decrypted-grid';
			videoItems.forEach((item, index) => {
				const src = resolveMediaSrc(item, payload.basePath);
				const link = document.createElement('a');
				link.className = 'diary-decrypted-media';
				link.href = src;
				link.setAttribute('data-lightbox-src', src);
				link.setAttribute('data-lightbox-type', 'video');
				link.setAttribute('aria-label', `${payload.title || 'Diary'} - video ${index + 1}`);

				if (isDirectVideoUrl(src)) {
					const video = document.createElement('video');
					video.preload = 'metadata';
					video.controls = true;
					video.playsInline = true;
					video.crossOrigin = 'anonymous';
					const source = document.createElement('source');
					source.src = src;
					const mime = getVideoMimeType(src);
					if (mime) source.type = mime;
					video.append(source);
					link.append(video);
				} else {
					const fallback = document.createElement('div');
					fallback.className = 'diary-decrypted-video-fallback';
					fallback.textContent = '外链视频';
					link.append(fallback);
				}

				const play = document.createElement('div');
				play.className = 'diary-decrypted-video-play';
				play.innerHTML = '<span>▶</span>';
				link.append(play);
				grid.append(link);
			});
			section.append(grid);
			container.append(section);
		}

		async function initDiaryPasswordProtection() {
			await loadCryptoLibraries();
			await loadMarkdownRenderer();

			const passwordInput = document.getElementById('diary-password-input');
			const unlockBtn = document.getElementById('diary-unlock-btn');
			const errorMessage = document.getElementById('diary-password-error');
			const protectionDiv = document.getElementById('diary-password-protection');
			const contentDiv = document.getElementById('diary-decrypted-content');
			const statusDiv = document.getElementById('diary-unlocked-status');
			if (!passwordInput || !unlockBtn || !errorMessage || !protectionDiv || !contentDiv || !statusDiv) return;
			function normalizeDiaryStoragePath(path) {
				try {
					return decodeURI(String(path || '')).replace(/\/+$/, '/') || '/';
				} catch (_) {
					return String(path || '').replace(/\/+$/, '/') || '/';
				}
			}

			const encodedDiaryPath = window.location.pathname.replace(/\/+$/, '/') || '/';
			const diaryPath = normalizeDiaryStoragePath(window.location.pathname);
			const passwordStorageKey = `diary-password-${diaryPath}`;
			const unlockedStorageKey = `diary-unlocked-${diaryPath}`;
			const legacyPasswordStorageKey = `diary-password-${encodedDiaryPath}`;
			const legacyUnlockedStorageKey = `diary-unlocked-${encodedDiaryPath}`;

			function showError(message) {
				errorMessage.textContent = message;
				errorMessage.hidden = false;
				passwordInput.focus();
			}

			async function unlockWithPassword(inputPassword, options = {}) {
				try {
					if (!bcrypt.compareSync(inputPassword, passwordHash)) {
						if (!options.silent) showError(i18nIncorrect);
						return false;
					}

					const decrypted = CryptoJS.AES.decrypt(encryptedPayload, inputPassword).toString(CryptoJS.enc.Utf8);
					if (!decrypted) {
						if (!options.silent) showError(i18nDecryptError);
						return false;
					}

					const payload = JSON.parse(decrypted);
					if (!payload || payload.__diaryPassword !== true) {
						if (!options.silent) showError(i18nDecryptError);
						return false;
					}

					contentDiv.innerHTML = '';
					renderMarkdown(payload.body || '', contentDiv);
					renderImages(payload.images || [], payload, contentDiv);
					renderVideos(payload.images || [], payload.videos || [], payload, contentDiv);
					protectionDiv.style.display = 'none';
					statusDiv.hidden = false;
					contentDiv.hidden = false;
					localStorage.setItem(passwordStorageKey, inputPassword);
					localStorage.setItem(unlockedStorageKey, 'true');
					window.dispatchEvent(new CustomEvent('diary-password-unlocked', {
						detail: { path: diaryPath }
					}));
					return true;
				} catch (error) {
					console.error('Failed to unlock diary', error);
					if (!options.silent) showError('解锁失败，请检查密码');
					return false;
				}
			}

			async function attemptUnlock() {
				const inputPassword = passwordInput.value.trim();
				if (!inputPassword) {
					showError('请输入密码');
					return;
				}

				unlockBtn.disabled = true;
				unlockBtn.textContent = i18nUnlocking;
				errorMessage.hidden = true;

				try {
					await unlockWithPassword(inputPassword);
				} finally {
					unlockBtn.disabled = false;
					unlockBtn.textContent = i18nUnlock;
				}
			}

			unlockBtn.addEventListener('click', attemptUnlock);
			passwordInput.addEventListener('keypress', (event) => {
				if (event.key === 'Enter') attemptUnlock();
			});

			const rememberedPassword = localStorage.getItem(passwordStorageKey) || localStorage.getItem(legacyPasswordStorageKey);
			if (rememberedPassword) {
				const restored = await unlockWithPassword(rememberedPassword, { silent: true });
				if (restored) return;
				localStorage.removeItem(passwordStorageKey);
				localStorage.removeItem(unlockedStorageKey);
				localStorage.removeItem(legacyPasswordStorageKey);
				localStorage.removeItem(legacyUnlockedStorageKey);
			}

			passwordInput.focus();
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initDiaryPasswordProtection);
		} else {
			initDiaryPasswordProtection();
		}
	})();
</script>
