---
/**
 * SidebarTOC - 侧边栏目录组件
 * 基于 Web Component 实现，支持 IntersectionObserver 滚动监听
 *
 * 从 Mizuki 上游迁移。
 */

import type { MarkdownHeading } from "astro";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
}

const { class: className } = Astro.props;
---

<table-of-contents class:list={[className, "group", "relative"]} id="sidebar-toc">
</table-of-contents>

<style is:global>
	:root {
		/* 你可以在这里修改展开后的目录宽度。22rem 约等于 352 像素。你可以把它改成 24rem, 26rem 等等 */
		--toc-expanded-width: 18rem;
	}

	/* 给正文容器的随动动画，不移动而是压缩宽度（需要使用 padding 配合 box-sizing） */
	/* 仅在页面有 TOC（即 html 拥有 has-toc）的情境下才生效，以防带去给没有目录的页面 */
	html.toc-expanded.has-toc #main-grid {
		/* 计算需要压缩的差值，并应用到外边距或内边距（这里依赖其 flex 容器或其他布局方式） */
		/* 在当前 Grid 布局下改变它的宽度可能会好一点 */
	}
	html.toc-expanded.toc-right.has-toc #main-grid {
		padding-right: var(--toc-shift, 0px) !important;
	}
	html.toc-expanded.toc-left.has-toc #main-grid {
		padding-left: var(--toc-shift, 0px) !important;
	}
	html.has-toc #main-grid, html.has-toc #top-row {
		transition: padding 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
		will-change: padding;
	}

	#toc-inner-wrapper {
		transition: width 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), padding 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), border-radius 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
		will-change: width, transform, padding;
		
		/* 默认常驻显示的圆角风格，仅在有 TOC 时显示背景 */
		border-radius: 0.75rem;
		
		/* 强制移除遮罩渐变 */
		mask-image: none !important;
		-webkit-mask-image: none !important;
	}

	html.has-toc #toc-inner-wrapper {
		background-color: transparent;
	}

    /* 暴力移除可能产生渐变的伪元素 */
    #toc-inner-wrapper::before, #toc-inner-wrapper::after,
    #toc::before, #toc::after,
    #toc-wrapper::before, #toc-wrapper::after {
        display: none !important;
        background: none !important;
        mask-image: none !important;
        -webkit-mask-image: none !important;
    }
	#toc-inner-wrapper.toc-expanded-active {
		width: var(--toc-expanded-width) !important;
		max-width: calc(100vw - 2rem);
		background-color: transparent !important;
		backdrop-filter: blur(12px);
		padding: 1rem 0.75rem !important;
		border: 1px solid var(--line-divider);
		border-radius: 1.25rem !important;
		box-shadow: none !important;
		z-index: 50 !important;
	}
	/* 如果它在右侧布局下（意味着目录在文章右侧），让它向左扩展，避免超出右侧屏幕；如果在左侧，向右扩展即可 */
	.toc-wrapper-right #toc-inner-wrapper.toc-expanded-active {
		transform: translateX(calc(var(--toc-width) - var(--toc-expanded-width) - 1rem)) !important;
	}
	.toc-wrapper-left #toc-inner-wrapper.toc-expanded-active {
		transform: translateX(1rem) !important;
	}
</style>

<script>
	import { JAPANESE_KATAKANA } from "./utils/japanese-katakana";
	import {
		extractHeadings,
		generateTOCItems,
		getTOCConfig,
		scrollToHeading,
	} from "./utils/toc-utils";

	import {
		calculateActiveHeadingRange,
		isInRange,
	} from "./hooks/useTocHighlight";

	import {
		throttle,
		calculateActiveIndicatorPosition,
	} from "./hooks/useTocScroll";

	class TableOfContents extends HTMLElement {
		tocEl: HTMLElement | null = null;
		scrollContainer: HTMLElement | null = null;
		visibleClass = "visible";
		observer: IntersectionObserver;
		anchorNavTarget: HTMLElement | null = null;
		headingIdxMap = new Map<string, number>();
		headings: HTMLElement[] = [];
		sections: HTMLElement[] = [];
		tocEntries: HTMLAnchorElement[] = [];
		active: boolean[] = [];
		activeIndicator: HTMLElement | null = null;
		navbarHeight = 80;

		constructor() {
			super();
			this.observer = new IntersectionObserver(
				this.markVisibleSection.bind(this),
				{ threshold: 0 },
			);
		}

		markVisibleSection = (entries: IntersectionObserverEntry[]) => {
			entries.forEach((entry) => {
				const id = (
					entry.target as HTMLElement
				).children[0]?.getAttribute("id");
				const idx = id ? this.headingIdxMap.get(id) : undefined;
				if (idx !== undefined) {
					this.active[idx] = entry.isIntersecting;
				}

				if (
					entry.isIntersecting &&
					this.anchorNavTarget ===
						(entry.target as HTMLElement).firstChild
				) {
					this.anchorNavTarget = null;
				}
			});

			if (!this.active.includes(true)) {
				this.fallback();
			}
			this.update();
		};

		toggleActiveHeading = () => {
			const { min, max } = calculateActiveHeadingRange(this.active);

			this.tocEntries.forEach((entry, i) => {
				if (this.active[i]) {
					entry.classList.add(this.visibleClass);
				} else {
					entry.classList.remove(this.visibleClass);
				}
			});

			if (min > max) {
				this.activeIndicator?.setAttribute("style", "opacity: 0");
			} else {
				const minEntry = this.tocEntries[min];
				const maxEntry = this.tocEntries[max];
				if (minEntry && maxEntry && this.tocEl) {
					const { top, height } = calculateActiveIndicatorPosition(
						this.tocEl,
						minEntry,
						maxEntry,
					);
					this.activeIndicator?.setAttribute(
						"style",
						`top: ${top}px; height: ${height}px`,
					);
				}
			}
		};

		scrollToActiveHeading = throttle(() => {
			const scrollContainer = this.scrollContainer || this.tocEl;
			if (this.anchorNavTarget || !this.tocEl || !scrollContainer) return;

			const activeEntries = this.tocEntries.filter((entry) =>
				entry.classList.contains(this.visibleClass),
			);
			if (activeEntries.length === 0) return;

			const topmost = activeEntries[0];
			const bottommost = activeEntries[activeEntries.length - 1];
			const tocHeight = scrollContainer.clientHeight;

			const visibleHeight =
				bottommost.getBoundingClientRect().bottom -
				topmost.getBoundingClientRect().top;

			let top: number;
			if (visibleHeight < 0.9 * tocHeight) {
				top = (topmost as HTMLElement).offsetTop - 32;
			} else {
				top = (bottommost as HTMLElement).offsetTop - tocHeight * 0.8;
			}

			scrollContainer.scrollTo({ top, left: 0, behavior: "smooth" });
		}, 100);

		update = () => {
			requestAnimationFrame(() => {
				this.toggleActiveHeading();
				this.scrollToActiveHeading();
			});
		};

		fallback = () => {
			if (!this.sections.length) return;

			for (let i = 0; i < this.sections.length; i++) {
				const rect = this.sections[i].getBoundingClientRect();
				if (
					isInRange(rect.top, 0, window.innerHeight) ||
					isInRange(rect.bottom, 0, window.innerHeight) ||
					(rect.top < 0 && rect.bottom > window.innerHeight)
				) {
					this.active[i] = true;
				} else if (rect.top > window.innerHeight) {
					break;
				}
			}
		};

		handleAnchorClick = (event: Event) => {
			const anchor = (event.composedPath() as EventTarget[]).find(
				(el) => el instanceof HTMLAnchorElement,
			) as HTMLAnchorElement | undefined;

			if (anchor) {
				event.preventDefault();
				const id = decodeURIComponent(anchor.hash?.substring(1) || "");
				scrollToHeading(id, this.navbarHeight);

				const idx = this.headingIdxMap.get(id);
				this.anchorNavTarget =
					idx !== undefined ? this.headings[idx] : null;
			}
		};

		connectedCallback() {
			const element =
				document.querySelector(".custom-md") ||
				document.querySelector(".prose") ||
				document.querySelector(".markdown-content");
			let initialized = false;

			const tryInit = () => {
				if (!initialized) {
					initialized = true;
					this.init();
				}
			};

			if (element) {
				element.addEventListener("animationend", tryInit, {
					once: true,
				});
				setTimeout(tryInit, 300);
			} else {
				tryInit();
				setTimeout(tryInit, 300);
			}
            
            // 监听 Swup 页面清理/加载事件，确保在页面切换后更新 TOC
            if (typeof window !== "undefined" && (window as any).swup) {
                // 使用 once 避免重复绑定 (但因为 web component 可能会被重置，还是要注意)
                // 更好的方式是保存 handler 引用并在 disconnectedCallback 中移除
                
                // 仅当还没绑定 handler 时绑定
                if (!this.swupHandlerBound) {
                    this.handleSwupContentReplace = () => {
                         // 稍微延迟以等待新内容渲染
                         setTimeout(() => {
                            this.regenerateTOC();
                            // 如果新页面没有toc，强制清理
                            const isPostPage = window.location.pathname.includes("/posts/") || 
                                             document.querySelector(".custom-md, .markdown-content") !== null;
                            if (!isPostPage) {
                                document.documentElement.classList.remove("has-toc", "toc-expanded", "toc-right", "toc-left");
                                document.documentElement.style.setProperty('--toc-shift', '0px');
                                const innerWrapper = this.closest("#toc-inner-wrapper");
                                if (innerWrapper) {
                                    innerWrapper.classList.remove("toc-expanded-active");
                                    innerWrapper.style.cssText = "";
                                    innerWrapper.style.display = 'none';
                                }
                            }
                         }, 200);
                    };
                    
                    (window as any).swup.hooks.on("content:replace", this.handleSwupContentReplace);
                    this.swupHandlerBound = true;
                }
            }
		}
        
        swupHandlerBound = false;
        handleSwupContentReplace: any = null;

        disconnectedCallback() {
            // 移除监听器
            if (typeof window !== "undefined" && (window as any).swup && this.handleSwupContentReplace) {
                (window as any).swup.hooks.off("content:replace", this.handleSwupContentReplace);
                this.swupHandlerBound = false;
            }
        }

		init() {
			this.regenerateTOC();
			this.tocEl = this;
			this.scrollContainer =
				(this.closest("#toc-inner-wrapper") as HTMLElement | null) ||
				this.tocEl;

			this.tocEl.addEventListener("click", this.handleAnchorClick, {
				capture: true,
			});

			this.activeIndicator = document.getElementById("active-indicator");

			this.tocEntries = Array.from(
				this.querySelectorAll<HTMLAnchorElement>("a[href^='#']"),
			);

			if (this.tocEntries.length === 0) return;

			this.sections = new Array(this.tocEntries.length);
			this.headings = new Array(this.tocEntries.length);

			for (let i = 0; i < this.tocEntries.length; i++) {
				const id = decodeURIComponent(
					this.tocEntries[i].hash?.substring(1) || "",
				);
				const heading = document.getElementById(id);
				const section = heading?.parentElement;
				if (
					heading instanceof HTMLElement &&
					section instanceof HTMLElement
				) {
					this.headings[i] = heading;
					this.sections[i] = section;
					this.headingIdxMap.set(id, i);
				}
			}
			this.active = new Array(this.tocEntries.length).fill(false);

			this.sections.forEach((section) => this.observer.observe(section));

			this.fallback();
			this.update();
		}

		resetTOC() {
			this.innerHTML = "";
			document.documentElement.classList.remove("has-toc");
			// 清理可能因 swup 页面切换而残留的父级容器样式
			const innerWrapper = this.closest("#toc-inner-wrapper");
			if (innerWrapper) {
				innerWrapper.classList.remove("toc-expanded-active");
				innerWrapper.style.cssText = ""; // 移除内联样式（特别是width）
				innerWrapper.style.display = 'none'; // 隐藏整个容器防止显示空背景
			}
			document.documentElement.style.setProperty('--toc-shift', '0px');
			document.documentElement.classList.remove("toc-expanded", "toc-right", "toc-left");
			
			// 强制移除残留的全局样式（以防万一）
			const expandedStyle = document.getElementById("toc-expanded-style");
			if (expandedStyle) expandedStyle.remove();
		}

		regenerateTOC(retryCount = 0) {
			const isPostPage =
				window.location.pathname.includes("/posts/") ||
				document.querySelector(".custom-md, .markdown-content") !==
					null;

			if (!isPostPage) {
				this.resetTOC();
				return;
			}
			
			// 确保容器可见
			const innerWrapper = this.closest("#toc-inner-wrapper");
			if (innerWrapper) {
				innerWrapper.style.display = '';
			}

			document.documentElement.classList.add("has-toc");

			const config = getTOCConfig();
			const headings = extractHeadings("#post-container");

			if (!headings.length) {
				if (retryCount < 10) {
					setTimeout(() => this.regenerateTOC(retryCount + 1), 300);
				}
				
                // 即使还在重试中，如果当前已经处于展开状态且没有找到标题，也应该先移除展开样式，避免"亚克力"残留
                this.resetTOC();
                
				return;
			}
			
			// 只有确保有内容了，才显示容器
			if (innerWrapper) {
				innerWrapper.style.display = '';
			}

			const items = generateTOCItems(headings, config);
			const minLevel = Math.min(...headings.map((h) => h.level));

			const toggleHTML = `
				<div class="sticky top-0 z-[100] w-full flex justify-end mb-2 pb-2 px-2 bg-transparent" style="margin-top: -1rem; padding-top: 1rem;">
					<button id="toc-expand-toggle" class="flex items-center justify-center p-1.5 rounded-xl bg-[var(--card-bg)] shadow-sm border border-[var(--line-divider)] hover:bg-[var(--btn-plain-bg-hover)] text-[var(--primary)] text-xs transition-all active:scale-95 cursor-pointer backdrop-blur-md" title="拓宽/恢复目录" aria-label="拓宽/恢复目录">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-panel-left-open"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="M9 3v18"/><path d="m14 9 3 3-3 3"/></svg>
					</button>
				</div>
			`;

			const tocHTML = items
				.map((item) => {
					const depthClass =
						item.depth === 0
							? "bg-[var(--toc-badge-bg)] text-[var(--btn-content)]"
							: item.depth === 1
								? "bg-[var(--toc-badge-bg)] text-[var(--btn-content)] opacity-80"
								: "bg-[var(--toc-badge-bg)] text-[var(--btn-content)] opacity-60";

					const badgeText = item.badge ?? "";
					const badge =
						item.depth === 0
							? `<div class="transition w-5 h-5 shrink-0 rounded-lg text-xs flex items-center justify-center font-bold ${depthClass}">${badgeText}</div>`
							: item.depth === 1
								? '<div class="transition w-2 h-2 rounded-[0.1875rem] bg-[var(--toc-badge-bg)]"></div>'
								: '<div class="transition w-2 h-2 rounded-[0.1875rem] bg-[var(--toc-badge-bg)] opacity-60"></div>';

					const padding =
						item.depth === 0
							? "pl-2"
							: item.depth === 1
								? "pl-6"
								: "pl-10";

					return `<a href="#${item.id}" class="${padding} px-2 flex gap-2 relative transition w-full min-h-9 rounded-xl hover:bg-[var(--toc-btn-hover)] active:bg-[var(--toc-btn-active)] py-2"><span class="flex items-center gap-2 mt-0.5">${badge}</span><span class="line-clamp-3 text-sm text-[var(--toc-text)] leading-tight break-words">${item.text}</span></a>`;
				})
				.join("");

			this.innerHTML =
				toggleHTML +
				tocHTML +
				'<div id="active-indicator" style="opacity: 0" class="-z-10 absolute bg-[var(--toc-btn-hover)] left-0 right-0 rounded-xl transition-all group-hover:bg-transparent border-2 border-[var(--toc-btn-hover)] group-hover:border-[var(--toc-btn-active)] border-dashed"></div>';

			// Bind toggle event
			const toggleBtn = this.querySelector("#toc-expand-toggle");
			// innerWrapper is already defined at the beginning of the function
			
			if (toggleBtn && innerWrapper) {
				const setShift = (isExpanded) => {
					const isRight = innerWrapper.closest('.toc-wrapper-right') !== null;
					if (isExpanded) {
						// Calculate layout shift to avoid overlap (only apply when screen > 1024px)
						if (window.innerWidth > 1024) {
							// 通过 CSS var 同步扩展的宽度，额外增加 2rem 的间距确保完全不重合
							document.documentElement.style.setProperty('--toc-shift', `calc((var(--toc-expanded-width) - var(--toc-width)) + 2rem)`);
						}
						document.documentElement.classList.add("toc-expanded");
						document.documentElement.classList.add(isRight ? "toc-right" : "toc-left");
					} else {
						document.documentElement.classList.remove("toc-expanded", "toc-right", "toc-left");
						document.documentElement.style.setProperty('--toc-shift', '0px');
					}
				};

				// Re-apply expanded state if it was persisted
				if (localStorage.getItem("toc-expanded") === "true") {
					innerWrapper.classList.add("toc-expanded-active");
					setShift(true);
					// Fallback re-apply in case layout wasn't ready
					setTimeout(() => setShift(true), 100);
				}
				
				toggleBtn.addEventListener("click", () => {
					const isExpanded = innerWrapper.classList.toggle("toc-expanded-active");
					setShift(isExpanded);
					localStorage.setItem("toc-expanded", isExpanded ? "true" : "false");
				});
			}
		}

		disconnectedCallback() {
			this.tocEl?.removeEventListener("click", this.handleAnchorClick);
			this.observer.disconnect();
		}
	}

	customElements.define("table-of-contents", TableOfContents);
</script>
