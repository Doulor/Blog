  // 让日记图片输入区支持拖拽排序（鼠标/触摸）
  function initDiaryImageSortable() {
    const container = document.getElementById('diaryImagesContainer');
    if (!container || container.dataset.sortInit === 'true') return;
    container.dataset.sortInit = 'true';

    let draggingItem = null;
    let startY = 0;

    container.addEventListener('pointerdown', (e) => {
      const handle = e.target.closest('.drag-handle');
      if (!handle) return;
      const item = handle.closest('.diary-image-input');
      if (!item) return;
      e.preventDefault();
      draggingItem = item;
      startY = e.clientY;
      item.classList.add('dragging');
      item.style.pointerEvents = 'none';
      item.style.transform = 'translate3d(0, 0, 0)';
      document.body.style.userSelect = 'none';
      document.body.style.cursor = 'grabbing';
    });

    window.addEventListener('pointermove', (e) => {
      if (!draggingItem) return;
      const deltaY = e.clientY - startY;
      draggingItem.style.transform = `translate3d(0, ${deltaY}px, 0)`;
      const elementUnder = document.elementFromPoint(e.clientX, e.clientY);
      const target = elementUnder?.closest('.diary-image-input');
      if (!target || target === draggingItem) return;
      const rect = target.getBoundingClientRect();
      const after = (e.clientY - rect.top) > rect.height / 2;
      container.insertBefore(draggingItem, after ? target.nextSibling : target);
    });

    const finishDrag = () => {
      if (!draggingItem) return;
      draggingItem.classList.remove('dragging');
      draggingItem.style.pointerEvents = '';
  draggingItem.style.transform = '';
  document.body.style.userSelect = '';
  document.body.style.cursor = '';
      draggingItem = null;
      const activeForm = document.querySelector('.form-content:not(.hidden)');
      if (activeForm) {
        const formType = activeForm.id.replace('Form', '');
        generateMarkdown(formType);
      }
    };

    window.addEventListener('pointerup', finishDrag);
    window.addEventListener('pointercancel', finishDrag);
  }

